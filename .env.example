# Database
DATABASE_URL="postgresql://user:password@host:5432/professor_website"

# Session
SESSION_SECRET="32-character-minimum-random-string-here"

# SMTP Email
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASS="smtp-password"

# Professor contact email
PROFESSOR_EMAIL="professor@university.edu"

# Base URL for sitemap and robots.txt
NEXT_PUBLIC_BASE_URL="https://yourwebsite.com"

# ── AI CHATBOT (OpenAI) ──
# Get your key at: https://platform.openai.com/api-keys
# Leave empty to disable AI chatbot (rule-based fallback will be used)
OPENAI_API_KEY=""

# ── ORCID SYNC ──
# Your ORCID iD (e.g. 0000-0002-1825-0097)
ORCID_ID=""

# ── MULTI-FACTOR AUTHENTICATION ──
# App name shown in authenticator apps (e.g. Google Authenticator)
MFA_APP_NAME="Professor Website"

# ── LIVE CHAT (Tawk.to) ──
# Get your property ID from https://tawk.to
# Format: PROPERTY_ID/WIDGET_ID  e.g. 64abc123def/1h2i3j4k5
# Leave empty to disable
NEXT_PUBLIC_TAWKTO_ID=""
